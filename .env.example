# JATA Environment Configuration
# Copy this file to .env and adjust values as needed.

# ── Frontend ─────────────────────────────────────────────
# Backend URL (optional in dev — auto-detects Expo dev server IP).
# For APK/production builds: set in eas.json env block before building.
# Example: EXPO_PUBLIC_BACKEND_URL=http://192.168.1.100:3000
# EXPO_PUBLIC_BACKEND_URL=http://localhost:3000

# ── Backend ──────────────────────────────────────────────
# Transit routing API (default: free public Transitous/MOTIS instance)
ROUTING_API_URL=https://api.transitous.org/api

# Geocoding API (default: free public Photon instance)
GEOCODING_API_URL=https://photon.komoot.io

# Server port
PORT=3000

# ── Optional: Google API Key ─────────────────────────────
# Users can enter a Google API Key in Settings > Advanced to
# switch from free APIs (Transitous/Photon) to Google APIs
# (Directions, Places, Maps). The key is stored on-device and
# sent per-request — never stored on the server.
# Required Google APIs: Directions API, Places API
